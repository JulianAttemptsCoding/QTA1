# Vertex worker image for agorasim: vLLM inference + HF download + GCS sync.
# Built via Cloud Build (K-1: no local heavy compute). Runs on n1-standard-8 + T4 (sm_75).
FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    HF_HUB_ENABLE_HF_TRANSFER=1 \
    PYTHONPATH=/app/src \
    NVIDIA_VISIBLE_DEVICES=all \
    NVIDIA_DRIVER_CAPABILITIES=compute,utility \
    LD_LIBRARY_PATH=/usr/local/nvidia/lib64:/usr/local/cuda/lib64
# ^ Vertex/nvidia-container-runtime mounts the GPU driver (libcuda.so.1) into
# /usr/local/nvidia/lib64; the slim base omits that dir from the loader path, so vLLM
# fails with "libcuda.so.1: cannot open shared object file" -> "Failed to infer device
# type". Exporting LD_LIBRARY_PATH + NVIDIA_* makes the injected driver discoverable.

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential git curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Heavy, rarely-changing deps first (Docker layer cache). Guided JSON decoding uses the
# lm-format-enforcer backend (bundled with vLLM) to avoid the `outlines` import chain,
# which pulls a broken `pyairports` dependency.
# vLLM pinned to 0.6.4.post1 (NOT 0.6.3.post1): the lm-format-enforcer bundled with 0.6.3
# does NOT enforce JSON-schema `maxLength` on strings, so small models ramble a long
# rationale and the JSON is truncated at max_tokens (valid-JSON ~0.18). 0.6.4.post1 ships a
# newer lm-format-enforcer that honors maxLength -> the rationale is capped at 240 chars and
# the object closes within budget (the operative fix for the G0 >=90% valid-JSON gate).
# torch pinned to the cu121 wheel first so vllm reuses it (T4 sm_75 CUDA build), matching a
# proven-working stack. transformers pinned 4.46.3: newer releases removed `LogitsWarper`,
# which lm-format-enforcer's transformers integration still imports (ImportError otherwise).
RUN pip install --upgrade pip && \
    pip install --index-url https://download.pytorch.org/whl/cu121 \
      "torch==2.5.1+cu121" "torchvision==0.20.1+cu121" && \
    pip install \
      "vllm==0.6.4.post1" \
      "transformers==4.46.3" \
      "huggingface_hub[hf_transfer]>=0.25,<1.0" \
      "google-cloud-storage>=2.18"

# Repo package + its light deps (numpy/pandas/pydantic/requests/pyyaml).
COPY pyproject.toml /app/pyproject.toml
COPY src /app/src
RUN pip install .

COPY prompts /app/prompts
COPY configs /app/configs
COPY scripts /app/scripts

CMD ["python", "-c", "import vllm, agorasim; print('agorasim worker ok, vllm', vllm.__version__)"]
